# WordPress Backend URL (no trailing slash)
NEXT_PUBLIC_WP_URL=https://u20poetryslam.at

# Resend API key für Formular-Versand (Home-Anmeldung, Lehrer-Anfrage, Kontakt)
RESEND_API_KEY=re_xxx_your_key_here

# Absender-Adresse (muss bei Resend verifiziert sein) und Empfänger
CONTACT_FROM="U20 Poetry Slam <noreply@u20poetryslam.at>"
CONTACT_TO=info@u20poetryslam.at

# Instagram Graph API — Posts von @u20slamwien auf Homepage & News
# Long-lived User Token (gültig 60 Tage, refresh via /api/instagram/refresh)
INSTAGRAM_ACCESS_TOKEN=IGQVJxxx_your_token_here
# Numerische User-ID des @u20slamwien-Accounts
INSTAGRAM_USER_ID=123456789

# Secret für Cron-Aufrufe (z.B. Token-Refresh, Vercel Cron)
CRON_SECRET=your_cron_secret_here
